# MapLibre GL Native token (if needed)
# MAPLIBRE_NATIVE_TOKEN=

# API Base URL
# NARS_API_BASE_URL=https://api.nars.example.com

# Feature flags
# ENABLE_ANALYTICS=false
# ENABLE_CRASHLYTICS=false

# SSL certificate pinning (optional — comma-separated, format: hostname=sha256/hash)
# SSL_CERT_HASHES=api.nars.example.com=sha256/AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Tile server URLs (optional — defaults to standard providers)
# TILE_SATELLITE=https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}
# TILE_STREET=https://tile.openstreetmap.org/{z}/{x}/{y}.png
# TILE_LIGHT=https://basemaps.cartocdn.com/light_all/{z}/{x}/{y}{ratio}.png
# TILE_DARK=https://basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{ratio}.png
