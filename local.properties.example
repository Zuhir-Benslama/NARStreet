# MapLibre GL Native token (if needed)
# MAPLIBRE_NATIVE_TOKEN=

# API Base URL
# NARS_API_BASE_URL=https://api.nars.example.com

# Feature flags
# ENABLE_ANALYTICS=false
# ENABLE_CRASHLYTICS=false

# SSL certificate pinning (optional — comma-separated, format: hostname=sha256/hash)
# SSL_CERT_HASHES=api.nars.example.com=sha256/AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
